{
  "name": "tube-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tube proxy engine — HTTPS/HTTP2 proxy + traffic recorder + WebSocket API",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --target=bun-darwin-arm64 ./src/index.ts --outfile=../dist/tube-engine",
    "build:linux": "bun build --compile --target=bun-linux-x64 ./src/index.ts --outfile=../dist/tube-engine",
    "build:win": "bun build --compile --target=bun-windows-x64 ./src/index.ts --outfile=../dist/tube-engine.exe"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  }
}
